<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.pratham.pralinesongs</string>

    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/python3</string>
        <string>/Users/pratham/life-os/praline_songs_sync.py</string>
    </array>

    <!-- run every hour -->
    <key>StartInterval</key>
    <integer>3600</integer>

    <!-- also run once right after login / load -->
    <key>RunAtLoad</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/Users/pratham/life-os/.praline_songs.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/pratham/life-os/.praline_songs.log</string>
</dict>
</plist>
